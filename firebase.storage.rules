
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Users can read and write their own evidence files
    match /evidence/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Users can read and write their own profile files
    match /profiles/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Public files can be read by anyone
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Allow authenticated users to read/write in general
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}