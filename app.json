{
  "expo": {
    "name": "Suraksha - Women Safety",
    "slug": "suraksha-women-safety",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#C0153E"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.suraksha.womensafety",
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Suraksha needs location to share your position in an emergency.",
        "NSLocationWhenInUseUsageDescription": "Suraksha needs location to share your position in an emergency.",
        "NSMicrophoneUsageDescription": "Suraksha records audio as evidence during SOS.",
        "NSCameraUsageDescription": "Suraksha records video and photos as evidence during SOS.",
        "NSContactsUsageDescription": "Suraksha needs contacts to set up your emergency trusted circle.",
        "NSMotionUsageDescription": "Suraksha uses motion sensors to detect falls and danger."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#C0153E"
      },
      "package": "com.suraksha.womensafety",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "RECORD_AUDIO",
        "READ_CONTACTS",
        "SEND_SMS",
        "CALL_PHONE",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "FOREGROUND_SERVICE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE",
        "WAKE_LOCK",
        "INTERNET"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-location",
      "expo-camera",
      "expo-av",
      "expo-sensors",
      "expo-contacts",
      "expo-media-library",
      "expo-notifications",
      "expo-task-manager"
    ],
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
